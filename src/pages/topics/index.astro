---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { topics } from '../../data/topics';

const lastUpdated = "2026-07-14";
const SITE_URL = import.meta.env.SITE_URL || 'https://finalize.ahmedbarkat1067.workers.dev';

const getTopicImage = (id: string) => {
  const images = {
    'memory-foam': '/images/mattresses/amerisleep-as3.webp',
    'cooling-technology': '/images/mattresses/brooklyn-bedding-aurora-luxe.webp',
    'pocketed-coils': '/images/mattresses/saatva-classic.webp',
    'spinal-alignment': '/images/mattresses/amerisleep-as2.webp',
    'motion-isolation': '/images/mattresses/casper-the-one.webp',
    'edge-support': '/images/mattresses/happsy.webp',
    'certipur-us': '/images/mattresses/bear-original.webp',
    'sleep-cycles': '/images/mattresses/leesa-original.webp',
  };
  return images[id as keyof typeof images] || '/images/mattresses/amerisleep-as3.webp';
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Mattress & Sleep Topics — PureSleep",
  "description": "The science behind sleep: memory foam, cooling technology, spinal alignment, motion isolation, sleep cycles, and more.",
  "url": `${SITE_URL}/topics/`,
  "dateModified": lastUpdated,
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": topics.map((topic, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "url": `${SITE_URL}/topics/${topic.id}/`,
      "name": topic.title
    }))
  }
};
---

<BaseLayout 
  title="Key Mattress & Sleep Topics — PureSleep" 
  description="Explore the science behind sleep: memory foam, cooling technology, spinal alignment, sleep cycles, and more."
  canonicalUrl={`${SITE_URL}/topics/`}
  machineReadableUrl={`${SITE_URL}/llms/topics.md`}
  lastUpdated={lastUpdated}
  ogImage="/images/mattresses/amerisleep-as3.webp"
  jsonLd={jsonLd}
>
  <main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-12 relative z-10 w-full flex flex-col gap-16">
    <header class="flex flex-col gap-6 items-center text-center max-w-4xl mx-auto">
      <h1 class="text-headline-lg font-headline-lg  text-primary font-bold">
        Key Mattress & Sleep Topics
      </h1>
      <p class="text-body-lg font-body-lg text-on-surface-variant max-w-3xl">
        Explore the science behind sleep: memory foam, cooling technology, spinal alignment, sleep cycles, and more.
      </p>
    </header>

    <div class="grid md:grid-cols-2 gap-px max-w-5xl mx-auto w-full border border-outline-variant/30 bg-outline-variant/30">
      {topics.map(topic => (
        <article class="bg-white p-6 md:p-8 flex flex-col gap-5" id={topic.id}>
          <img src={getTopicImage(topic.id)} alt="" class="w-full aspect-[16/9] object-cover" loading="lazy" />
          <div>
            <h2 class="text-title-lg md:text-headline-sm text-primary font-bold">
              <a href={`/topics/${topic.id}/`} class="hover:text-secondary underline-offset-4 hover:underline">{topic.title}</a>
            </h2>
            <p class="text-body-md text-on-surface-variant mt-3 leading-relaxed">{topic.description}</p>
          </div>
          <div class="mt-auto flex items-center justify-between gap-4 text-body-sm">
            <span class="text-on-surface-variant">{topic.relatedMattresses.length} related reviews</span>
            <a href={`/topics/${topic.id}/`} class="text-primary font-bold underline underline-offset-4 hover:text-secondary">Read guide</a>
          </div>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>
