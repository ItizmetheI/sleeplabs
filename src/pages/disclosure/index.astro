---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { COMMERCIAL_RELATIONSHIP_DISCLOSURE, LINK_DISCLOSURE } from '../../lib/disclosure';

const SITE_URL = import.meta.env.SITE_URL || 'https://finalize.ahmedbarkat1067.workers.dev';
const lastUpdated = "2026-05-01";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Disclosure",
    "url": `${SITE_URL}/disclosure/`,
    "description": "PureSleep's material-relationship, outbound-link, and ranking disclosure.",
    "publisher": {
      "@type": "Organization",
      "name": "PureSleep",
      "url": SITE_URL
    }
  }
];
---

<BaseLayout
  title="Disclosure — PureSleep"
  description="PureSleep's material-relationship, outbound-link, and ranking disclosure."
  canonicalUrl={`${SITE_URL}/disclosure/`}
  lastUpdated={lastUpdated}
  jsonLd={jsonLd}
>
  <main class="max-w-[760px] mx-auto px-margin-mobile md:px-0 py-16 relative z-10 flex flex-col gap-16">

    <header class="flex flex-col gap-6">
      <h1 class="text-headline-lg font-headline-lg text-primary font-bold">Disclosure</h1>
      <p class="text-body-lg text-on-surface-variant leading-relaxed">
        {COMMERCIAL_RELATIONSHIP_DISCLOSURE} {LINK_DISCLOSURE}
      </p>
    </header>

    <section class="flex flex-col gap-6">
      <h2 class="text-headline-md font-headline-md text-primary italic border-b border-outline-variant/30 pb-4">How Links Work On This Site</h2>
      <div class="glass-panel p-8 rounded-3xl border border-white/60 flex flex-col gap-4">
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          Product links go to manufacturer or retailer pages. PureSleep does not receive per-click or per-sale affiliate commissions from those links. Amerisleep, Zoma, Vaya, or FORM may benefit when a reader purchases one of their products.
        </p>
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          Rankings follow the locked score data and stated category criteria. The same seven fields and 0-10 scale apply to affiliated and non-affiliated brands.
        </p>
      </div>
    </section>

    <section class="flex flex-col gap-6">
      <h2 class="text-headline-md font-headline-md text-primary italic border-b border-outline-variant/30 pb-4">Who Writes Our Reviews</h2>
      <div class="glass-panel p-8 rounded-3xl border border-white/60">
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          Reviews are written and scored under the <a href="/about/#editorial-team" class="text-secondary hover:text-primary underline underline-offset-4 font-bold transition-colors">PureSleep Editorial Team</a> organizational byline using our standardized 7-metric editorial system. PureSleep does not present a named clinician as a medical reviewer.
        </p>
      </div>
    </section>

    <section class="flex flex-col gap-4">
      <div class="flex flex-wrap gap-3">
        <a href="/methodology" class="text-primary hover:text-secondary underline underline-offset-4 font-bold transition-colors">Read our full scoring methodology →</a>
        <span class="text-outline-variant hidden md:inline self-center">·</span>
        <a href="/editorial-policy" class="text-primary hover:text-secondary underline underline-offset-4 font-bold transition-colors">Read our editorial policy →</a>
      </div>
    </section>

  </main>
</BaseLayout>
