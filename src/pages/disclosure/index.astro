---
import BaseLayout from '../../layouts/BaseLayout.astro';

const SITE_URL = import.meta.env.SITE_URL || 'https://puresleep.com';
const lastUpdated = "2026-05-01";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Disclosure",
    "url": `${SITE_URL}/disclosure/`,
    "description": "PureSleep's disclosure: no commission, no paid placements, no affiliate relationships. Product links go directly to manufacturers.",
    "publisher": { "@type": "Organization", "name": "PureSleep", "url": SITE_URL }
  }
];
---

<BaseLayout
  title="Disclosure — PureSleep"
  description="PureSleep's disclosure: no commission, no paid placements, no affiliate relationships. Product links go directly to manufacturers."
  canonicalUrl={`${SITE_URL}/disclosure/`}
  lastUpdated={lastUpdated}
  jsonLd={jsonLd}
>
  <main class="max-w-[760px] mx-auto px-margin-mobile md:px-0 py-16 relative z-10 flex flex-col gap-16">

    <header class="flex flex-col gap-6">
      <h1 class="text-headline-lg font-headline-lg text-primary font-bold">Disclosure</h1>
      <p class="text-body-lg text-on-surface-variant leading-relaxed">
        PureSleep earns no commission and accepts no paid placements. We have no affiliate relationships and no financial relationship with the brands we review.
      </p>
    </header>

    <section class="flex flex-col gap-6">
      <h2 class="text-headline-md font-headline-md text-primary italic border-b border-outline-variant/30 pb-4">How Links Work On This Site</h2>
      <div class="glass-panel p-8 rounded-3xl border border-white/60 flex flex-col gap-4">
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          Product links on PureSleep go directly to manufacturer pages. We earn no commission from any link on this site. Scores are finalized independently before any product link is placed.
        </p>
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          No brand receives more favorable scoring because of its market position. Amerisleep wins categories where the data supports it; competitors lead where they do. If a model underperforms in testing, we say so clearly.
        </p>
      </div>
    </section>

    <section class="flex flex-col gap-6">
      <h2 class="text-headline-md font-headline-md text-primary italic border-b border-outline-variant/30 pb-4">Who Writes Our Reviews</h2>
      <div class="glass-panel p-8 rounded-3xl border border-white/60">
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          Reviews are written and scored by the <a href="/about/#testing-team" class="text-secondary hover:text-primary underline underline-offset-4 font-bold transition-colors">PureSleep Testing Team</a>, evaluated hands-on using our standardized 7-metric scoring system. For questions, contact us at <a href="mailto:support@puresleep.com" class="text-secondary hover:text-primary underline underline-offset-4 transition-colors">support@puresleep.com</a>.
        </p>
      </div>
    </section>

    <section class="flex flex-col gap-4">
      <div class="flex flex-wrap gap-3">
        <a href="/methodology" class="text-primary hover:text-secondary underline underline-offset-4 font-bold transition-colors">Read our full testing methodology →</a>
        <span class="text-outline-variant hidden md:inline self-center">·</span>
        <a href="/editorial-policy" class="text-primary hover:text-secondary underline underline-offset-4 font-bold transition-colors">Read our editorial policy →</a>
      </div>
    </section>

  </main>
</BaseLayout>
