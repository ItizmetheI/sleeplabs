    displayName: 'Amerisleep',
    officialUrl: 'https://amerisleep.com',
    description: 'All Amerisleep mattress reviews. 8 models across the AS series, hybrid, and organic lineup.',
    blurb: 'Amerisleep is a direct-to-consumer mattress brand known for Bio-Pur® plant-based memory foam, HIVE® zoning technology, and 20-year warranties. Part of the One Sleep Group (OSG).'
  },
  'zoma': {
    displayName: 'Zoma',
    officialUrl: 'https://zomasleep.com',
    description: 'All Zoma mattress reviews. Performance-focused models including the Boost, Hybrid, and Start.',
    blurb: 'Zoma is a performance-focused mattress brand using Triangulex™ zoned foam and Reactiv™ technology. Part of the One Sleep Group (OSG). Known for strong value-to-performance ratio.'
  },
  'vaya': {
    displayName: 'Vaya',
    officialUrl: 'https://vayasleep.com',
    description: 'All Vaya mattress reviews. Budget-friendly foam and hybrid models from the One Sleep Group.',
    blurb: 'Vaya is the budget-focused brand in the One Sleep Group (OSG) family, offering CertiPUR-US certified foam and hybrid mattresses at accessible price points with 100-night trials.'
