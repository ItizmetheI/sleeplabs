---
import { allMattresses } from '../../data/mattresses';
import BaseLayout from '../../layouts/BaseLayout.astro';

const SITE_URL = import.meta.env.SITE_URL || 'https://production-domain-not-set.example';

const BRAND_META: Record<string, { displayName: string; description: string; officialUrl: string; blurb: string }> = {
