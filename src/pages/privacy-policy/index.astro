---
import BaseLayout from '../../layouts/BaseLayout.astro';
const SITE_URL = import.meta.env.SITE_URL || 'https://finalize.ahmedbarkat1067.workers.dev';
const CONTACT_EMAIL = import.meta.env.PUBLIC_CONTACT_EMAIL;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Privacy Policy — PureSleep",
  "url": `${SITE_URL}/privacy-policy/`,
  "description": "PureSleep privacy policy. How we collect, use, and protect your information.",
  "dateModified": "2026-07-14"
};
---

<BaseLayout
  title="Privacy Policy — PureSleep"
  description="PureSleep privacy policy. How we collect, use, and protect your information."
  canonicalUrl={`${SITE_URL}/privacy-policy/`}
  jsonLd={jsonLd}
>
  <main class="max-w-[760px] mx-auto px-margin-mobile md:px-0 py-16 relative z-10 flex flex-col gap-10">

    <header>
      <h1 class="text-headline-lg font-headline-lg text-primary font-bold mb-4">Privacy Policy</h1>
      <p class="text-body-md text-on-surface-variant">Last updated: July 14, 2026</p>
    </header>

    <div class="flex flex-col gap-8 text-body-md text-on-surface-variant leading-relaxed">

      <section>
        <h2 class="text-title-lg font-title-lg text-primary mb-3 font-bold">1. Information We Collect</h2>
        <p>PureSleep is a mattress review and sleep-content publication. We do not require account creation or collect personal information for standard site use. We may collect anonymized usage data (page views, referring URLs, browser type) via analytics tools to improve site performance.</p>
      </section>

      <section>
        <h2 class="text-title-lg font-title-lg text-primary mb-3 font-bold">2. External Links</h2>
        <p>This site contains links to manufacturer and retailer pages for the products we review. PureSleep does not receive per-click or per-sale commissions from those links. Third-party sites have their own privacy practices governed by their own policies; refer to each site's current privacy policy for details.</p>
      </section>

      <section>
        <h2 class="text-title-lg font-title-lg text-primary mb-3 font-bold">3. Cookies</h2>
        <p>We may use cookies for analytics and site functionality. We do not use cookies to track personal information or serve targeted advertising. You can disable cookies in your browser settings without affecting your ability to use this site.</p>
      </section>

      <section>
        <h2 class="text-title-lg font-title-lg text-primary mb-3 font-bold">4. Third-Party Services</h2>
        <p>We use third-party analytics services (such as Google Analytics) that may collect anonymized data about your visit. These services have their own privacy policies. We do not sell data to third parties.</p>
      </section>

      <section>
        <h2 class="text-title-lg font-title-lg text-primary mb-3 font-bold">5. Your Rights (GDPR / CCPA)</h2>
        <p>If you are located in the European Economic Area or California, you may have rights to request access to, correction of, or deletion of personal data. Since PureSleep does not require accounts for standard site use, such requests may be resolved by confirming that no account data exists.</p>
      </section>

      <section>
        <h2 class="text-title-lg font-title-lg text-primary mb-3 font-bold">6. Contact</h2>
        {CONTACT_EMAIL ? (
          <p>For privacy-related inquiries, email <a href={`mailto:${CONTACT_EMAIL}`} class="text-primary underline">{CONTACT_EMAIL}</a>.</p>
        ) : (
          <p>A dedicated privacy contact must be configured with the final production domain before launch.</p>
        )}
      </section>

    </div>
  </main>
</BaseLayout>
