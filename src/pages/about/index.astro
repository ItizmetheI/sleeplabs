---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { COMMERCIAL_RELATIONSHIP_DISCLOSURE, LINK_DISCLOSURE } from '../../lib/disclosure';

const SITE_URL = import.meta.env.SITE_URL || 'https://finalize.ahmedbarkat1067.workers.dev';
const lastUpdated = "2026-05-01";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About PureSleep",
    "url": `${SITE_URL}/about/`,
    "description": "PureSleep is a multi-brand mattress review publication covering 59 models across 24 brands.",
    "publisher": {
      "@type": "Organization",
      "name": "PureSleep",
      "url": SITE_URL,
      "parentOrganization": { "@type": "Organization", "name": "Amerisleep" }
    }
  }
];
---

<BaseLayout
  title="About PureSleep — Mattress Reviews Across 24 Brands"
  description="PureSleep is a multi-brand mattress review publication covering 59 models across 24 brands using one published 7-metric rubric."
  canonicalUrl={`${SITE_URL}/about/`}
  lastUpdated={lastUpdated}
  jsonLd={jsonLd}
>
  <main class="max-w-[760px] mx-auto px-margin-mobile md:px-0 py-16 relative z-10 flex flex-col gap-16">

    <header class="flex flex-col gap-6">
      <h1 class="text-headline-lg font-headline-lg text-primary font-bold">About PureSleep</h1>
      <p class="text-body-lg text-on-surface-variant leading-relaxed">
        PureSleep covers 59 models across 24 brands, and every score uses the same published 7-metric rubric.
      </p>
    </header>

    <section class="flex flex-col gap-6">
      <h2 class="text-headline-md font-headline-md text-primary italic border-b border-outline-variant/30 pb-4">What We Do</h2>
      <div class="glass-panel p-8 rounded-3xl border border-white/60 flex flex-col gap-4">
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          We test mattresses from 24 brands using a standardized 7-metric scoring system. Each model is evaluated hands-on before any score is published.
        </p>
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          {LINK_DISCLOSURE} Scores and rankings are based on the same published rubric across affiliated and non-affiliated brands.
        </p>
        <a href="/methodology" class="text-primary hover:text-secondary underline underline-offset-4 font-bold transition-colors w-fit">Read our full testing methodology →</a>
      </div>
    </section>

    <section id="testing-team" class="flex flex-col gap-6">
      <h2 class="text-headline-md font-headline-md text-primary italic border-b border-outline-variant/30 pb-4">Our Testing Team</h2>
      <div class="glass-panel p-8 rounded-3xl border border-white/60 flex flex-col gap-4">
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          Reviews are written and scored by the PureSleep Testing Team, an organizational byline for the people responsible for PureSleep's mattress evaluations. The published rubric considers sleep position, body-weight guidance, construction, and comfort preferences; PureSleep does not claim clinical testing or attribute medical review to a named clinician.
        </p>
        <a href="/methodology" class="text-primary hover:text-secondary underline underline-offset-4 font-bold transition-colors w-fit">How we test →</a>
      </div>
    </section>

    <section class="flex flex-col gap-6">
      <h2 class="text-headline-md font-headline-md text-primary italic border-b border-outline-variant/30 pb-4">How We Cover 24 Brands</h2>
      <div class="flex flex-col gap-4 text-body-md text-on-surface-variant leading-relaxed">
        <p>Our 7-metric scoring system applies identically across all 59 models: overall, value, edge support, trial period, response time, motion transfer, and cooling &amp; breathability. The same rubric means every model is genuinely comparable across brands.</p>
        <p>Scores are finalized from hands-on testing before any product link is placed. No brand receives more favorable scoring because of its market position; category order follows the locked score data and stated selection criteria.</p>
        <p>Coverage depth varies by available model information and comparison relevance, but every published score uses the same seven fields and 0–10 scale.</p>
      </div>
    </section>

    <section class="flex flex-col gap-6">
      <h2 class="text-headline-md font-headline-md text-primary italic border-b border-outline-variant/30 pb-4">Material Relationships and Commercial Disclosure</h2>
      <div class="glass-panel p-8 rounded-3xl border border-white/60">
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          {COMMERCIAL_RELATIONSHIP_DISCLOSURE} {LINK_DISCLOSURE} This relationship is disclosed so readers can weigh it alongside our published scores, methodology, and cross-brand comparisons.
        </p>
      </div>
    </section>

  </main>
</BaseLayout>
