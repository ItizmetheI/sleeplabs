---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { comparisons } from '../../data/comparisons';
import { mattresses } from '../../data/mattresses';

const lastUpdated = "2026-05-01";
const formattedDateModified = new Date(lastUpdated).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric'
});
const SITE_URL = import.meta.env.SITE_URL || 'https://puresleep.com';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Amerisleep Mattress Comparisons 2026 — PureSleep",
  "description": "Side-by-side Amerisleep mattress comparisons. AS2 vs AS3, AS3 vs AS5, AS3 vs AS6, Organica vs AS3, AS2 vs AS5, AS6 vs Organica. Tested by the PureSleep testing team.",
  "url": `${SITE_URL}/comparison/`,
  "dateModified": lastUpdated,
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": comparisons.map((c, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "url": `${SITE_URL}/comparison/${c.slug}`,
      "name": `${mattresses.find(m => m.id === c.mattressAId)?.name ?? ''} vs ${mattresses.find(m => m.id === c.mattressBId)?.name ?? ''}`
    }))
  }
};
---

<BaseLayout 
  title="Amerisleep Mattress Comparisons 2026: AS2 vs AS3, AS3 vs AS5, AS6 vs Organica | PureSleep" 
  description="Side-by-side Amerisleep comparisons: AS2 vs AS3, AS3 vs AS5, AS3 vs AS6, Organica vs AS3. Scores, dimensions, prices, and expert verdict for every matchup."
  canonicalUrl={`${SITE_URL}/comparison/`}
  lastUpdated={lastUpdated}
  ogImage="https://images.unsplash.com/photo-1542362567-b07e54358753?auto=format&fit=crop&w=1200&q=80"
  jsonLd={jsonLd}
>
  <main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-12 relative z-10 w-full flex flex-col gap-16">
    
    <header class="flex flex-col gap-6 items-center text-center max-w-4xl mx-auto">
      <h1 class="text-headline-lg font-headline-lg  text-primary font-bold">
        Amerisleep Mattress Comparisons 2026
      </h1>
      <p class="text-body-lg font-body-lg text-on-surface-variant max-w-3xl">
        Side-by-side comparisons of every Amerisleep model. Same core technology, different firmness, feel, and construction — find exactly which model fits your sleep style.
      </p>
    </header>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {comparisons.map(comparison => {
        const m1 = mattresses.find(m => m.id === comparison.mattressAId);
        const m2 = mattresses.find(m => m.id === comparison.mattressBId);
        if (!m1 || !m2) return null;
        
        return (
          <a href={`/comparison/${comparison.slug}`} class="glass-panel flex flex-col rounded-3xl overflow-hidden hover:-translate-y-1 hover:shadow-lg transition-all border border-white/60 p-8 gap-6 group">
            <h2 class="text-title-lg font-title-lg text-primary mb-1 group-hover:text-secondary transition-colors">
              {m1.name} vs {m2.name}
            </h2>
            <div class="flex gap-4 items-center">
              <div class="flex-1 h-32 rounded-xl overflow-hidden border border-outline-variant/30">
                 <img src={m1.image} alt={m1.name} class="w-full h-full object-cover" />
              </div>
              <span class="text-label-lg font-bold text-on-surface-variant italic font-headline-lg">VS</span>
              <div class="flex-1 h-32 rounded-xl overflow-hidden border border-outline-variant/30">
                 <img src={m2.image} alt={m2.name} class="w-full h-full object-cover" />
              </div>
            </div>
            <p class="text-body-md text-on-surface-variant">{comparison.verdict}</p>
            <span class="text-primary font-label-sm uppercase tracking-widest font-bold mt-auto pt-4 border-t border-outline-variant/20">Read Comparison →</span>
          </a>
        );
      })}
    </section>

  </main>
</BaseLayout>
