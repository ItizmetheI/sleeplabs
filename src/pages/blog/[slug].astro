---
import { blogPosts } from '../../data/blogs-generated';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { articleList, articleTable, toArticleBody } from '../../lib/schemaArticleBody';
import { EDITORIAL_INDEPENDENCE_DISCLOSURE, LINK_DISCLOSURE } from '../../lib/disclosure';
import { formatDateOnly } from '../../lib/dateFormat';
import { getLegacyBestBlogRedirect } from '../../lib/legacyBlogRedirects';
import { requiresBlogSourceReview } from '../../lib/blogSourceReview';
import { FIRDOUS_FARHAD } from '../../lib/editorialPeople';

export function getStaticPaths() {
  return blogPosts.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;

const redirectTo = post.redirectTo || getLegacyBestBlogRedirect(post.slug);
if (redirectTo) {
  return Astro.redirect(redirectTo, 301);
}

const SITE_URL = import.meta.env.SITE_URL || 'https://finalize.ahmedbarkat1067.workers.dev';

const sourceReviewPending = requiresBlogSourceReview(post);

const blogArticleBody = toArticleBody(
  post.title,
  'Quick Answer',
  post.directAnswer,
  sourceReviewPending
    ? 'No mattress can diagnose, treat, or cure any health condition. This article provides general comfort and sleep-product information only; talk to a doctor about pain or medical concerns.'
    : null,
  sourceReviewPending
    ? ['Reviewer Assignment', `${FIRDOUS_FARHAD.name}, ${FIRDOUS_FARHAD.role.toLowerCase()}. ${FIRDOUS_FARHAD.credentials} This page does not carry completed review attribution until article-specific sources and final reviewer approval are complete.`]
    : null,
  post.sections.map((section: any) => [
    section.heading,
    section.content,
    section.hasBulletList && section.bulletItems
      ? articleList(section.heading ? `${section.heading} - Key Points` : 'Key Points', section.bulletItems)
      : null,
    section.hasTable && section.tableData
      ? articleTable(
        section.heading ? `${section.heading} - Table` : 'Comparison Table',
        section.tableData.headers,
        section.tableData.rows,
      )
      : null,
  ]),
  post.productRefs?.length
    ? articleTable(
      'Referenced Products - prices are recorded reference values, not live offers; verify current terms on the official product page',
      ['Product', 'Recorded Reference Price', 'Product URL'],
      post.productRefs.map((product: any) => [product.productName, product.salePrice, product.productUrl]),
    )
    : null,
  'Multi-Brand Context',
  'Product examples in this article are not a complete category ranking. See the Best Mattress rankings and Reviews index for the full 59-model, 24-brand scored dataset.',
  'Frequently Asked Questions',
  post.faqs.map((faq: any) => [`Question: ${faq.question}`, `Answer: ${faq.answer}`]),
  'About PureSleep',
  `${EDITORIAL_INDEPENDENCE_DISCLOSURE} ${LINK_DISCLOSURE}`,
);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": post.schemaType === 'HowTo' ? ['Article', 'HowTo'] : 'Article',
  "headline": post.title,
  "description": post.metaDescription,
  "image": post.ogImage.startsWith('http') ? post.ogImage : `${SITE_URL}${post.ogImage}`,
  "author": {
    "@type": "Organization",
    "@id": `${SITE_URL}/about/#editorial-team`,
    "name": "PureSleep Editorial Team",
    "url": `${SITE_URL}/about/#editorial-team`
  },
  "publisher": {
    "@type": "Organization",
    "@id": `${SITE_URL}/#organization`,
    "name": "PureSleep",
    "url": SITE_URL
  },
  "datePublished": post.datePublished,
  "dateModified": post.dateModified,
  "mainEntityOfPage": `${SITE_URL}/blog/${post.slug}/`,
  "articleBody": blogArticleBody,
  "citation": [
    ...post.productRefs.map(product => product.productUrl),
    `${SITE_URL}/editorial-policy/`
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": post.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, 
      "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, 
      "name": "Blog", "item": SITE_URL + "/blog/" },
    { "@type": "ListItem", "position": 3, 
      "name": post.title, 
      "item": SITE_URL + "/blog/" + post.slug + "/" }
  ]
};

const jsonLd = [articleSchema, faqSchema, breadcrumbSchema];

const formatProse = (text: string) => {
  let formatted = text || '';
  
  if (!formatted.includes('<p>') && !formatted.includes('<br>')) {
     // Safely try to break into smaller paragraphs by looking for ". "
     // without destroying any text or tags.
     const parts = formatted.split('. ');
     let paragraphs = [];
     let currentParagraph = "";
     parts.forEach((part, i) => {
        currentParagraph += part + (i < parts.length - 1 ? ". " : "");
        // Group every 3 sentences
        if ((i + 1) % 3 === 0 || i === parts.length - 1) {
           paragraphs.push(`<p class="mb-5 last:mb-0">${currentParagraph.trim()}</p>`);
           currentParagraph = "";
        }
     });
     formatted = paragraphs.join("");
  }
  
  // Highlight terms after paragraphing so tags don't get split.
  formatted = formatted.replace(/Bio-Pur®/g, `<span class="bg-primary/10 text-primary border border-primary/30 rounded-md px-1.5 py-0.5 font-semibold text-[15px] whitespace-nowrap">Bio-Pur®</span>`);
  formatted = formatted.replace(/HIVE® technology/g, `<span class="bg-secondary/10 text-secondary border border-secondary/30 rounded-md px-1.5 py-0.5 font-semibold text-[15px] whitespace-nowrap font-sans">HIVE® Technology</span>`);
  formatted = formatted.replace(/HIVE® Technology/g, `<span class="bg-secondary/10 text-secondary border border-secondary/30 rounded-md px-1.5 py-0.5 font-semibold text-[15px] whitespace-nowrap font-sans">HIVE® Technology</span>`);
  formatted = formatted.replace(/Refresh Fabric/g, `<span class="bg-blue-50 text-blue-700 border border-blue-300 rounded-md px-1.5 py-0.5 font-semibold text-[15px] whitespace-nowrap">Refresh Fabric</span>`);
  
  return formatted;
};
---

<BaseLayout
  title={post.metaTitle}
  description={post.metaDescription}
  ogTitle={post.ogTitle}
  ogDescription={post.ogDescription}
  ogImage={post.ogImage}
  ogType="article"
  canonicalUrl={`${SITE_URL}/blog/${post.slug}/`}
  lastUpdated={post.dateModified}
  jsonLd={jsonLd}
  noindex={sourceReviewPending}
>
  <article class="w-full min-w-0 max-w-[760px] mx-auto px-margin-mobile md:px-0 py-stack-lg">

    <!-- Breadcrumb -->
    <nav class="text-label-sm font-label-sm text-on-surface-variant mb-8 uppercase tracking-normal">
      <a href="/" class="hover:text-secondary transition-colors">Home</a>
      <span class="mx-2">·</span>
      <a href="/blog/" class="hover:text-secondary transition-colors">Blog</a>
      <span class="mx-2">·</span>
      <span class="text-primary">{post.category.replace(/-/g, ' ')}</span>
    </nav>

    <!-- Category pill -->
    <div class="inline-block text-label-sm font-label-sm uppercase tracking-normal text-secondary bg-secondary/10 px-3 py-1.5 rounded-md mb-6 font-bold">
      {post.category.replace(/-/g, ' ')}
    </div>

    <!-- H1 -->
    <h1 class="text-display-lg font-display-lg text-primary leading-tight mb-6">
      {post.title}
    </h1>

    <!-- Direct Answer Box — LLM signal -->
    <div class="bg-white p-6 rounded-lg border border-outline-variant border-l-4 border-l-secondary mb-8">
      <p class="text-label-sm font-label-sm uppercase tracking-normal text-secondary mb-2 font-bold">Quick Answer</p>
      <p class="text-body-lg text-on-background leading-relaxed">{post.directAnswer}</p>
    </div>

    {sourceReviewPending && (
      <div class="bg-amber-50 border border-amber-300 rounded-lg p-5 mb-8 text-body-md text-amber-950" role="note">
        <p class="font-bold mb-2">Editorial status: source review pending</p>
        <p>This page is excluded from search indexing until its health or sleep-science claims have explicit citations and final review. It provides general information only. A mattress cannot diagnose, treat, or cure a health condition; talk to a qualified professional about medical concerns.</p>
        <p class="mt-3"><strong>Reviewer assigned:</strong> <a href={FIRDOUS_FARHAD.path} class="font-bold underline underline-offset-4">{FIRDOUS_FARHAD.name}</a>, {FIRDOUS_FARHAD.role.toLowerCase()}. {FIRDOUS_FARHAD.credentials} Assignment is not presented as completed review.</p>
      </div>
    )}

    <!-- Byline -->
    <div class="flex items-start mb-8 pb-8 border-b border-outline-variant/30">
      <div class="flex flex-wrap items-center gap-4 text-label-sm font-label-sm text-on-surface-variant uppercase tracking-normal">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-md bg-primary text-white flex items-center justify-center font-bold text-lg">P</div>
          <span>By {post.author.name}</span>
        </div>
        <span>· <time datetime={post.dateModified}>Updated: {formatDateOnly(post.dateModified)}</time></span>
        <span>· {post.readTimeMinutes} min read</span>
      </div>
    </div>

    <!-- Hero image -->
    <div class="w-full aspect-[16/9] rounded-lg overflow-hidden mb-12 border border-outline-variant bg-surface-variant">
      <img src={post.ogImage} alt={post.title} class="w-full h-full object-cover" loading="lazy" onerror="this.onerror=null; this.src='/og-default.jpg';" />
    </div>

    <!-- Table of Contents -->
    {post.sections.filter(s => s.heading).length > 0 && (
      <div class="w-full min-w-0 bg-white p-5 sm:p-8 rounded-lg mb-12 border border-outline-variant overflow-hidden">
        <h2 class="text-label-sm font-label-sm uppercase tracking-normal text-primary font-bold mb-5 flex items-center gap-2">
          Table of Contents
        </h2>
        <ul class="space-y-3">
          {post.sections.filter(s => s.heading).map((section, idx) => (
            <li class="pl-4 border-l-2 border-outline-variant/30 hover:border-secondary transition-colors relative">
              <div class="absolute w-1.5 h-1.5 rounded-full bg-secondary/50 -left-[4px] top-2 border border-white"></div>
              <a href={`#section-${idx}`} class="block min-w-0 break-words text-body-md text-on-surface-variant hover:text-primary transition-colors font-medium">
                {section.heading}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Article sections -->
    {post.sections.map((section, index) => {
      // Check if section mentions high performance rating scores
      const scoreMatch = section.content.match(/\b([89]\.\d)\/10\b/);
      const firstScore = scoreMatch ? scoreMatch[1] : null;

      // Check if the section focuses on clinical/spinal alignment
      const sectionId = section.heading ? `section-${post.sections.filter(s => s.heading).indexOf(section)}` : `content-${index}`;

      return (
        <div id={sectionId} class="mb-12 scroll-mt-24 border-b border-outline-variant/10 pb-10 last:border-b-0">
          <!-- Heading -->
          {section.heading && section.headingLevel === 2 && (
            <h2 class="text-headline-lg font-headline-lg text-primary mb-6 leading-tight flex items-center gap-3">
              <span class="w-1.5 h-8 bg-secondary rounded-sm inline-block"></span>
              {section.heading}
            </h2>
          )}
          {section.heading && section.headingLevel === 3 && (
            <h3 class="text-headline-md font-headline-md text-primary mb-4 font-bold flex items-center gap-2">
               <span class="text-secondary/50">#</span> {section.heading}
            </h3>
          )}

          <!-- Score Badge Accent -->
          {firstScore && (
            <div class="inline-flex items-center gap-2 bg-amber-50 border border-amber-300 text-amber-900 rounded-md px-3.5 py-1.5 mb-4 text-xs font-bold uppercase tracking-normal">
              <span>Score referenced:</span>
              <span class="text-amber-600 font-extrabold text-sm">{firstScore}/10</span>
            </div>
          )}

          <!-- Content Prose -->
          {section.heading === null ? (
            <div class="text-body-lg text-on-surface-variant leading-relaxed font-sans first-letter:text-6xl first-letter:font-bold first-letter:text-primary first-letter:mr-3 first-letter:float-left first-letter:font-serif first-letter:italic first-letter:leading-none select-all" set:html={formatProse(section.content)} />
          ) : (
            <div class="text-body-lg text-on-surface-variant leading-relaxed font-sans select-all" set:html={formatProse(section.content)} />
          )}

          

          <!-- Bullet List Grid -->
          {section.hasBulletList && section.bulletItems && (
            <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
              {section.bulletItems.map(item => (
                <div class="flex items-start gap-3 bg-surface border border-outline-variant rounded-lg p-4">
                  <span class="p-1 rounded-full bg-secondary/10 text-secondary shrink-0 text-[10px] mt-0.5 font-sans font-extrabold w-5 h-5 flex items-center justify-center border border-secondary/15">
                    ✓
                  </span>
                  <p class="text-body-md text-on-surface-variant leading-relaxed font-medium">{item}</p>
                </div>
              ))}
            </div>
          )}

          <!-- High-Contrast Table formatting -->
          {section.hasTable && section.tableData && (
            <div class="mt-8 mb-6 bg-white border border-outline-variant rounded-lg overflow-x-auto">
              <table class="w-full min-w-[640px] text-left">
                <thead class="bg-primary text-white border-b border-primary-container/20">
                  <tr>
                    {section.tableData.headers.map(h => (
                      <th class="py-4 px-5 text-[11px] font-label-sm uppercase tracking-normal font-extrabold">{h}</th>
                    ))}
                  </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant/10 bg-white">
                  {section.tableData.rows.map(row => (
                    <tr class="hover:bg-primary/[0.02] transition-colors duration-200">
                      {row.map((cell, cellIdx) => (
                        <td class={`py-4 px-5 text-body-md text-on-surface-variant ${cellIdx === 0 ? 'font-bold text-primary' : ''}`}>
                          {cell}
                        </td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
          
        </div>
      );
    })}

    {post.productRefs.length > 0 && (
      <section class="my-12 border-y border-outline-variant/30 py-8" aria-labelledby="referenced-products">
        <h2 id="referenced-products" class="text-headline-sm font-bold text-primary mb-3">Referenced Products</h2>
        <p class="text-body-sm text-on-surface-variant mb-5">
          {EDITORIAL_INDEPENDENCE_DISCLOSURE} These links go to official product pages; verify current price, shipping, return, trial, and warranty terms before purchase.
        </p>
        <div class="flex flex-col divide-y divide-outline-variant/20 border-y border-outline-variant/20">
          {post.productRefs.map(ref => (
            <a href={ref.productUrl} target="_blank" rel="noopener noreferrer" class="flex items-center justify-between gap-4 py-4 text-primary hover:text-secondary">
              <span class="font-bold">{ref.productName}</span>
              <span class="text-label-sm uppercase tracking-normal">Official product page →</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <aside class="my-10 border-l-4 border-secondary pl-5 py-1 text-body-sm text-on-surface-variant">
      <strong class="text-on-surface">Multi-brand context:</strong> Product examples in this article are not a complete category ranking. See the <a href="/best/overall/" class="text-primary underline underline-offset-4">Best Mattress rankings</a> and <a href="/reviews/" class="text-primary underline underline-offset-4">Reviews index</a> for the full 59-model, 24-brand scored dataset.
    </aside>

    <!-- Author Box -->
    <div class="my-16 bg-white rounded-lg p-8 border border-outline-variant flex flex-col sm:flex-row gap-6 items-center sm:items-start text-center sm:text-left">
      <div class="w-20 h-20 rounded-lg bg-primary text-white flex items-center justify-center font-bold text-3xl shrink-0">
        <span>{post.author.name.charAt(0)}</span>
      </div>
      <div>
        <h3 class="text-headline-sm font-headline-sm text-primary mb-2 font-bold">{post.author.name}</h3>
        <p class="text-body-md text-on-surface-variant leading-relaxed mb-4">
          PureSleep Editorial Team is the organizational byline for multi-editor articles. The team organizes source records, maintains scorecards, and publishes corrections without claiming laboratory or clinical testing.
        </p>
        <div class="flex items-center justify-center sm:justify-start gap-4 text-label-sm uppercase tracking-normal font-bold">
          <a href="/about/" class="text-secondary hover:text-primary transition-colors">Read Our Story</a>
          <span class="text-outline-variant">|</span>
          <a href="/methodology/" class="text-secondary hover:text-primary transition-colors">How We Score</a>
        </div>
      </div>
    </div>

    <!-- FAQ section -->
    <div class="mt-12 border-t border-outline-variant/30 pt-12">
      <h2 class="text-headline-lg font-headline-lg text-primary mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {post.faqs.map(faq => (
          <div class="bg-white rounded-lg p-6 border border-outline-variant border-l-4 border-l-secondary">
            <h3 class="text-body-lg font-bold text-primary mb-3">
              {faq.question}
            </h3>
            <p class="text-body-md text-on-surface-variant leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Related reading (internal links) -->
    <div class="mt-12 border-t border-outline-variant/30 pt-12">
      <h3 class="text-label-sm font-label-sm uppercase tracking-normal text-secondary mb-6 font-bold">Related Reading</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {post.internalLinks.map(link => (
          <a href={link.url} class="bg-white border border-outline-variant p-5 rounded-lg hover:border-secondary transition-colors group">
            <span class="text-body-md text-primary font-bold group-hover:text-secondary transition-colors">{link.anchorText} →</span>
          </a>
        ))}
      </div>
    </div>

  </article>
</BaseLayout>
