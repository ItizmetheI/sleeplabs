---
import { allMattresses } from '../../data/mattresses';
import { articleList, articleTable, toArticleBody } from '../../lib/schemaArticleBody';
import { COMMERCIAL_RELATIONSHIP_DISCLOSURE, LINK_DISCLOSURE } from '../../lib/disclosure';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustSignals from '../../components/TrustSignals.astro';

export function getStaticPaths() {
  return allMattresses.map(m => ({
    params: { id: m.id },
    props: { mattress: m }
  }));
}

const { mattress } = Astro.props;

const SITE_URL = import.meta.env.SITE_URL || 'https://finalize.ahmedbarkat1067.workers.dev';
const canonicalUrl = `${SITE_URL}/reviews/${mattress.id}/`;
const absoluteHeroImage = mattress.heroImage.startsWith('http') ? mattress.heroImage : `${SITE_URL}${mattress.heroImage}`;
const productId = `${canonicalUrl}#product`;
const reviewId = `${canonicalUrl}#review`;
const trialLabel = mattress.trialNights > 0 ? `${mattress.trialNights} Nights` : 'No Home Trial Recorded';
const officialSourceLabel = mattress.availabilityNote ? 'View Official Source' : 'Check Latest Price';

const reviewArticleBody = toArticleBody(
  `${mattress.name} Review (2026): Scores, Construction, Pros and Cons`,
  articleList('Best For', mattress.bestFor),
  articleList('Not Ideal For', mattress.cons.slice(0, 3)),
  articleTable('Specs at a Glance', ['Spec', 'Value'], [
    ['Type', mattress.type.replace('-', ' ')],
    ['Firmness', `${mattress.firmness.replace('-', ' ')} (${mattress.firmnessScale}/10)`],
    ['Thickness', mattress.thickness],
    ['Trial Period', trialLabel],
    ['Warranty', `${mattress.warrantyYears} Years`],
    ['Certifications', mattress.certifications.join(', ')],
  ]),
  ...(mattress.availabilityNote ? ['Availability Note', mattress.availabilityNote] : []),
  'Quick Verdict',
  mattress.verdict,
  mattress.summary,
  articleList('What We Loved', mattress.pros),
  articleList('Points to Consider', mattress.cons),
  'Detailed Performance Analysis',
  `The locked scorecard records the ${mattress.name} at ${mattress.firmnessScale}/10 (${mattress.firmness}) and identifies its strongest fit for ${mattress.bestFor.slice(0, 3).join(', ')}. Fit guidance is editorial and varies by body type, sleep position, and comfort preference.`,
  `Scores: Overall ${mattress.scores.overall}/10. Value ${mattress.scores.value}/10. Edge Support ${mattress.scores.edgeSupport}/10. Trial Period ${mattress.scores.trialPeriod}/10. Response Time ${mattress.scores.responseTime}/10. Motion Transfer ${mattress.scores.motionTransfer}/10. Cooling & Breathability ${mattress.scores.coolingBreathability}/10.`,
  `Certification labels listed for this model: ${mattress.certifications.join(', ')}. Verify current certification status on the brand's official site or the certifying body's database before purchasing.`,
  'Inside the Mattress',
  mattress.layers.map((layer: any, index: number) =>
    `${index + 1}. ${layer.name} (${layer.thickness}). ${layer.material}. ${layer.description}`
  ),
  'How This Review Is Scored',
  `This review uses PureSleep's locked seven-metric editorial scorecard: Overall, Value, Edge Support, Trial Period, Response Time, Motion Transfer, and Cooling & Breathability. Scores are editorial comparisons, not clinical findings, laboratory measurements, manufacturer ratings, or collected customer ratings. ${COMMERCIAL_RELATIONSHIP_DISCLOSURE} ${LINK_DISCLOSURE}`,
  'Frequently Asked Questions',
  mattress.faqs.map((faq: any) => [`Question: ${faq.question}`, `Answer: ${faq.answer}`]),
  'Our Verdict',
  mattress.verdict,
  'Price note: Prices below are reference values captured in the source dataset, not live offers. Verify current pricing, shipping, return, trial, and warranty terms on the brand site before purchase.',
  articleTable(
    'Sizes & Reference Pricing',
    ['Size', 'Dimensions', 'Recorded Original Price', 'Recorded Sale Price'],
    mattress.sizePricing.map((sp: any) => [sp.size, sp.dimensions, sp.priceOriginal, sp.priceSale])
  )
);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${canonicalUrl}#article`,
    "headline": `${mattress.name} Review: Is It Worth It in 2026?`,
    "description": mattress.summary,
    "articleBody": reviewArticleBody,
    "author": {
      "@type": "Organization",
      "name": "PureSleep",
      "url": SITE_URL
    },
    "dateModified": mattress.dateModified,
    "datePublished": mattress.dateReviewed,
    "publisher": {
      "@type": "Organization",
      "name": "PureSleep",
      "url": SITE_URL
    },
    "image": absoluteHeroImage,
    "mainEntityOfPage": canonicalUrl,
    "mainEntity": { "@id": productId },
    "isPartOf": { "@type": "CollectionPage", "name": "PureSleep Reviews", "url": `${SITE_URL}/reviews/` },
    "about": [
      { "@id": productId },
      { "@type": "Article", "name": "PureSleep Scoring Methodology", "url": `${SITE_URL}/methodology/` }
    ],
    "citation": [mattress.affiliateUrl, `${SITE_URL}/methodology/`]
  },
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "@id": productId,
    "url": canonicalUrl,
    "name": mattress.name,
    "brand": { "@type": "Brand", "name": mattress.brand },
    "description": mattress.summary,
    "image": absoluteHeroImage,
    "sameAs": mattress.affiliateUrl,
    "review": {
      "@type": "Review",
      "@id": reviewId,
      "name": `${mattress.name} Editorial Review`,
      "url": canonicalUrl,
      "reviewBody": mattress.verdict,
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": mattress.scores.overall,
        "bestRating": "10"
      },
      "author": {
        "@type": "Organization",
        "name": "PureSleep Editorial Team",
        "url": `${SITE_URL}/about/#editorial-team`
      },
      "publisher": {
        "@type": "Organization",
        "name": "PureSleep",
        "url": SITE_URL
      },
      "datePublished": mattress.dateReviewed,
      "dateModified": mattress.dateModified
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
      { "@type": "ListItem", "position": 2, "name": "Reviews", "item": `${SITE_URL}/reviews/` },
      { "@type": "ListItem", "position": 3, "name": `${mattress.name} Review`, "item": `${SITE_URL}/reviews/${mattress.id}/` }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": mattress.faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];
---

<BaseLayout
  title={`${mattress.name} Review (2026) | PureSleep`}
  description={mattress.summary}
  ogTitle={`${mattress.name} Review (2026)`}
  ogImage={mattress.heroImage}
  ogType="article"
  canonicalUrl={canonicalUrl}
  machineReadableUrl={`${SITE_URL}/llms/reviews-${mattress.id}.md`}
  lastUpdated={mattress.dateModified}
  jsonLd={jsonLd}
>
  <main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-12 relative z-10 w-full flex flex-col gap-16">
    
    <header class="flex flex-col gap-6 items-center text-center max-w-4xl mx-auto">
      <h1 class="text-headline-lg font-headline-lg  text-primary font-bold">
        {mattress.name} Review (2026): Scores, Construction, Pros &amp; Cons
      </h1>
      <TrustSignals dateModified={mattress.dateModified} />
    </header>

    {mattress.availabilityNote && (
      <aside class="w-full max-w-4xl mx-auto border border-amber-300 bg-amber-50 px-6 py-5 rounded-xl text-amber-950" aria-label="Model availability note">
        <strong class="block mb-1">Availability note</strong>
        <p class="text-body-md leading-relaxed">{mattress.availabilityNote}</p>
      </aside>
    )}

    <!-- Hero Image -->
    <div class="w-full h-[400px] md:h-[600px] rounded-[32px] overflow-hidden shadow-2xl relative border border-white/60 bg-white">
      <img src={mattress.heroImage} alt={`${mattress.name} official product image`} class="w-full h-full object-contain" />
    </div>

    <div class="flex flex-col lg:flex-row gap-12 items-start">
      
      <!-- Main Content -->
      <article class="flex-1 flex flex-col gap-12 w-full">
        
        
<!-- Best For / Not Ideal For -->
<section class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div class="glass-panel p-6 rounded-2xl border border-green-200/50">
    <h3 class="text-label-sm font-label-sm uppercase tracking-widest text-green-700 font-bold mb-4">Best For</h3>
    <ul class="flex flex-col gap-2">
      {mattress.bestFor.map((item: string) => (
        <li class="flex items-center gap-2 text-body-md text-on-surface-variant">
          <span class="text-green-600 font-bold">✓</span> {item}
        </li>
      ))}
    </ul>
  </div>
  <div class="glass-panel p-6 rounded-2xl border border-red-200/50">
    <h3 class="text-label-sm font-label-sm uppercase tracking-widest text-red-600 font-bold mb-4">Not Ideal For</h3>
    <ul class="flex flex-col gap-2">
      {mattress.cons.slice(0, 3).map((item: string) => (
        <li class="flex items-center gap-2 text-body-md text-on-surface-variant">
          <span class="text-red-400 font-bold">✗</span> {item}
        </li>
      ))}
    </ul>
  </div>
</section>

        <!-- Specs at a Glance -->
        <section class="flex flex-col gap-4">
          <h2 class="text-headline-sm font-headline-sm text-primary font-bold">Specs at a Glance</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
            <div class="glass-panel p-4 rounded-xl border border-outline-variant/20">
              <span class="text-label-sm font-label-sm uppercase tracking-widest text-on-surface-variant">Type</span>
              <p class="font-bold text-on-surface mt-1 capitalize">{mattress.type.replace('-', ' ')}</p>
            </div>
            <div class="glass-panel p-4 rounded-xl border border-outline-variant/20">
              <span class="text-label-sm font-label-sm uppercase tracking-widest text-on-surface-variant">Firmness</span>
              <p class="font-bold text-on-surface mt-1 capitalize">{mattress.firmness.replace('-', ' ')} ({mattress.firmnessScale}/10)</p>
            </div>
            <div class="glass-panel p-4 rounded-xl border border-outline-variant/20">
              <span class="text-label-sm font-label-sm uppercase tracking-widest text-on-surface-variant">Thickness</span>
              <p class="font-bold text-on-surface mt-1">{mattress.thickness}</p>
            </div>
            <div class="glass-panel p-4 rounded-xl border border-outline-variant/20">
              <span class="text-label-sm font-label-sm uppercase tracking-widest text-on-surface-variant">Trial Period</span>
              <p class="font-bold text-on-surface mt-1">{trialLabel}</p>
            </div>
            <div class="glass-panel p-4 rounded-xl border border-outline-variant/20">
              <span class="text-label-sm font-label-sm uppercase tracking-widest text-on-surface-variant">Warranty</span>
              <p class="font-bold text-on-surface mt-1">{mattress.warrantyYears} Years</p>
            </div>
            <div class="glass-panel p-4 rounded-xl border border-outline-variant/20">
              <span class="text-label-sm font-label-sm uppercase tracking-widest text-on-surface-variant">Certifications</span>
              <p class="font-bold text-on-surface mt-1">{mattress.certifications.join(', ')}</p>
            </div>
          </div>
          {mattress.certifications.length > 0 && (
            <p class="text-xs text-on-surface-variant italic">
              Certifications are self-reported by the manufacturer. Verify current certification status on the brand's official site or the certifying body's database before purchasing.
            </p>
          )}
        </section>

        <!-- Quick Verdict Box -->
        <section class="glass-panel-heavy p-8 rounded-3xl border border-secondary/20 shadow-[0_8px_32px_rgba(37,99,235,0.05)]">
          <h2 class="text-title-lg font-title-lg text-primary mb-4 italic">Quick Verdict</h2>
          <p class="text-body-lg font-body-lg text-primary font-bold">{mattress.verdict}</p>
          <p class="mt-4 text-on-surface-variant leading-relaxed">
            {mattress.summary}
          </p>
        </section>

        <!-- Pros and Cons -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-green-50/50 p-8 rounded-3xl border border-green-200">
            <h3 class="text-title-md font-title-md text-green-800 mb-6 flex items-center gap-2">
               <span class="text-xl">✓</span> What We Loved
            </h3>
            <ul class="flex flex-col gap-4">
              {mattress.pros.map(pro => (
                <li class="flex gap-3 text-on-surface-variant items-start">
                  <span class="text-green-600 mt-1">•</span>
                  <span>{pro}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-red-50/50 p-8 rounded-3xl border border-red-200">
            <h3 class="text-title-md font-title-md text-red-800 mb-6 flex items-center gap-2">
              <span class="text-xl">✗</span> Points to Consider
            </h3>
            <ul class="flex flex-col gap-4">
              {mattress.cons.map(con => (
                <li class="flex gap-3 text-on-surface-variant items-start">
                  <span class="text-red-500 mt-1">•</span>
                  <span>{con}</span>
                </li>
              ))}
            </ul>
          </div>
        </section>

        <!-- Detailed Review Content -->
        <section class="flex flex-col gap-6">
          <h2 class="text-headline-md font-headline-md text-primary italic border-b border-outline-variant/30 pb-4">Detailed Performance Analysis</h2>
          <p class="leading-relaxed text-on-surface-variant">
            The locked scorecard records the {mattress.name} at {mattress.firmnessScale}/10 ({mattress.firmness}) and identifies its strongest fit for {mattress.bestFor.slice(0,3).join(', ')}. Fit guidance is editorial and varies by body type, sleep position, and comfort preference.
          </p>
          <p class="leading-relaxed text-on-surface-variant">
            Value: {mattress.scores.value}/10. Edge Support: {mattress.scores.edgeSupport}/10. Cooling &amp; Breathability: {mattress.scores.coolingBreathability}/10. Scores are editorial comparisons from the approved source dataset, not clinical findings, laboratory measurements, manufacturer ratings, or collected customer ratings.
          </p>
          <p class="leading-relaxed text-on-surface-variant">
            Certified {mattress.certifications.join(' and ')}. Backed by a {mattress.trialNights}-night trial and a {mattress.warrantyYears}-year warranty.
          </p>
        </section>

        <!-- Inside the Mattress (Layers) -->
        <section class="flex flex-col gap-8">
          <h2 class="text-headline-md font-headline-md text-primary italic border-b border-outline-variant/30 pb-4">Inside the Mattress</h2>
          <div class="grid grid-cols-1 gap-6">
            {mattress.layers.map((layer, index) => (
               <div class="glass-panel p-6 rounded-2xl flex flex-col md:flex-row gap-6 items-start border border-white/50">
                 <div class="bg-primary/5 text-primary font-bold text-xl rounded-xl w-12 h-12 flex items-center justify-center shrink-0">
                   {index + 1}
                 </div>
                 <div class="flex flex-col gap-2">
                   <h3 class="text-title-md font-title-md text-on-surface">
                     {layer.name} <span class="text-body-md font-normal text-on-surface-variant ml-2 bg-surface px-2 py-1 rounded-md border border-outline-variant/20">{layer.thickness}</span>
                   </h3>
                   <span class="text-label-sm font-label-sm text-secondary uppercase tracking-widest">{layer.material}</span>
                   <p class="text-on-surface-variant leading-relaxed mt-2">{layer.description}</p>
                 </div>
               </div>
            ))}
          </div>
        </section>

        <!-- Scoring Method -->
        <section class="glass-panel p-8 rounded-3xl border border-white/60 flex flex-col gap-5">
          <h2 class="text-headline-sm font-headline-sm text-primary font-bold">How This Review Is Scored</h2>
          <p class="text-body-md text-on-surface-variant leading-relaxed">
            This review uses PureSleep's locked seven-metric editorial scorecard: <strong class="text-on-surface">Overall, Value, Edge Support, Trial Period, Response Time, Motion Transfer, and Cooling &amp; Breathability</strong>. PureSleep does not present these ratings as laboratory measurements, clinical findings, manufacturer scores, or collected customer ratings.
          </p>
          <p class="text-body-md text-on-surface-variant leading-relaxed">
            {COMMERCIAL_RELATIONSHIP_DISCLOSURE} {LINK_DISCLOSURE} The same published scoring rubric is used across every covered brand.
          </p>
          <a href="/methodology" class="text-primary hover:text-secondary font-bold underline underline-offset-4 transition-colors text-body-md w-fit">
            Read our full scoring methodology →
          </a>
        </section>

        <!-- FAQs -->
        <section class="flex flex-col gap-6 mb-12">
          <h2 class="text-headline-md font-headline-md text-primary italic border-b border-outline-variant/30 pb-4">Frequently Asked Questions</h2>
          <div class="flex flex-col gap-4">
            {mattress.faqs.map(faq => (
              <details class="group bg-white rounded-2xl border border-outline-variant/30 overflow-hidden shadow-sm">
                <summary class="flex justify-between items-center cursor-pointer p-6 font-title-md text-on-surface font-bold list-none">
                  {faq.question}
                  <span class="transition group-open:rotate-180">
                    <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                  </span>
                </summary>
                <div class="p-6 pt-0 text-on-surface-variant leading-relaxed border-t border-outline-variant/10">
                  {faq.answer}
                </div>
              </details>
            ))}
          </div>
        </section>
        
      
<!-- Our Verdict -->
<section class="glass-panel-heavy p-8 rounded-3xl border border-secondary/20">
  <h2 class="text-headline-md font-headline-md text-primary italic mb-4">Our Verdict</h2>
  <p class="text-body-lg text-on-surface-variant leading-relaxed mb-6">{mattress.verdict}</p>
  <a href={mattress.affiliateUrl} target="_blank" rel="noopener noreferrer"
    class="inline-flex items-center bg-primary text-white px-8 py-4 rounded-full font-bold text-label-sm uppercase tracking-widest hover:bg-primary/90 transition-colors shadow-lg">
    {officialSourceLabel} →
  </a>
  <p class="text-xs text-on-surface-variant mt-3">{LINK_DISCLOSURE}</p>
</section>

        </article>

      <!-- Sidebar Scorecard -->
      <aside class="w-full lg:w-[400px] shrink-0 flex flex-col gap-8 sticky top-[100px]">
        
        <div class="glass-panel-heavy p-8 rounded-3xl border border-white/60 shadow-xl flex flex-col gap-8">
          
          <!-- Overall Score -->
          <div class="flex flex-col items-center justify-center pt-4 pb-6 border-b border-outline-variant/30">
            <span class="text-label-sm font-label-sm uppercase tracking-widest text-secondary font-bold mb-2">Overall Score</span>
            <div class="flex items-baseline justify-center gap-2 leading-none">
              <span class="text-[64px] sm:text-[80px] font-headline-lg font-bold italic text-primary">{mattress.scores.overall}</span>
              <span class="text-title-md text-on-surface-variant font-normal">/10</span>
            </div>
          </div>

          <!-- Detailed Metrics -->
          <div class="flex flex-col gap-6">
            {Object.entries({
              'Value': mattress.scores.value,
              'Edge Support': mattress.scores.edgeSupport,
              'Trial Period': mattress.scores.trialPeriod,
              'Response Time': mattress.scores.responseTime,
              'Motion Transfer': mattress.scores.motionTransfer,
              'Cooling & Breathability': mattress.scores.coolingBreathability,
            }).map(([label, score]) => (
              <div class="flex flex-col gap-2">
                <div class="flex justify-between items-center text-body-md font-body-md">
                  <span class="text-on-surface font-bold">{label}</span>
                  <span class="text-primary font-bold">{score}</span>
                </div>
                <div class="w-full bg-outline-variant/20 h-2.5 rounded-full overflow-hidden">
                  <div class="bg-secondary h-full rounded-full" style={`width: ${score * 10}%`}></div>
                </div>
              </div>
            ))}
          </div>

          <!-- Sizes & Pricing Table -->
          <div class="flex flex-col gap-3 pt-6 border-t border-outline-variant/30">
            <h3 class="text-label-sm font-label-sm uppercase tracking-widest text-secondary font-bold">Sizes & Reference Pricing</h3>
            <p class="text-xs text-on-surface-variant">Recorded dataset values, not live offers. Verify current price and policies on the brand site.</p>
            <div class="flex flex-col gap-0 border border-outline-variant/20 rounded-2xl overflow-hidden text-sm">
              {mattress.sizePricing.map((sp, i) => (
                <div class={`flex flex-col px-4 py-3 ${i % 2 === 0 ? 'bg-transparent' : 'bg-surface/50'} border-b border-outline-variant/10 last:border-b-0`}>
                  <div class="flex justify-between items-center">
                    <span class="font-bold text-on-surface">{sp.size}</span>
                    <div>
                      <span class="line-through text-on-surface-variant text-xs mr-1">{sp.priceOriginal}</span>
                      <span class="font-bold text-secondary">{sp.priceSale}</span>
                    </div>
                  </div>
                  <span class="text-on-surface-variant text-xs mt-0.5">{sp.dimensions}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Call to Action -->
          <div class="pt-6 border-t border-outline-variant/30 w-full">
             <a href={mattress.affiliateUrl} target="_blank" rel="noopener noreferrer" class="w-full block text-center bg-primary hover:bg-primary/90 text-on-primary py-4 px-6 rounded-xl font-label-lg font-bold tracking-wide uppercase transition-colors shadow-lg">
               {officialSourceLabel}
             </a>
             <p class="text-xs text-on-surface-variant text-center mt-2">{LINK_DISCLOSURE}</p>
          </div>
        </div>
        
      </aside>

    </div>

    <!-- Related Comparisons & Topics -->
    {(mattress.relatedComparisons?.length > 0 || mattress.relatedTopics?.length > 0) && (
      <section class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-8 border-t border-outline-variant/20">
        {mattress.relatedComparisons?.length > 0 && (
          <div class="flex flex-col gap-4">
            <h3 class="text-label-sm font-label-sm uppercase tracking-widest text-secondary font-bold">Compare This Mattress</h3>
            <div class="flex flex-col gap-2">
              {mattress.relatedComparisons.map((slug: string) => (
                <a href={`/comparison/${slug}`} class="text-primary hover:text-secondary underline underline-offset-4 font-bold text-body-md transition-colors">
                  {slug.replace('amerisleep-', '').replace(/-vs-/, ' vs ').split(' ').map((w: string) => w.toUpperCase()).join(' ')} →
                </a>
              ))}
            </div>
          </div>
        )}
        {mattress.relatedTopics?.length > 0 && (
          <div class="flex flex-col gap-4">
            <h3 class="text-label-sm font-label-sm uppercase tracking-widest text-secondary font-bold">Related Topics</h3>
            <div class="flex flex-col gap-2">
              {mattress.relatedTopics.map((id: string) => (
                <a href={`/topics/${id}`} class="text-primary hover:text-secondary underline underline-offset-4 font-bold text-body-md transition-colors">
                  {id.replace(/-/g, ' ').split(' ').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')} →
                </a>
              ))}
            </div>
          </div>
        )}
      </section>
    )}
  </main>
</BaseLayout>
