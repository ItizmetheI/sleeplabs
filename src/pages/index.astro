---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero';
import StatsRow from '../components/StatsRow';
import FindYourMatch from '../components/FindYourMatch';
import ScoreSheet from '../components/ScoreSheet';
import UseCases from '../components/UseCases';
import LatestGuides from '../components/LatestGuides';
import Methodology from '../components/Methodology';
import FinalPick from '../components/FinalPick';
import { allMattresses } from '../data/mattresses';
import { comparisons } from '../data/comparisons';
import { formatDateOnly } from '../lib/dateFormat';

const SITE_URL = import.meta.env.SITE_URL || 'https://finalize.ahmedbarkat1067.workers.dev';
const featuredPicks = [
  { id: 'amerisleep-as3', label: 'Best Overall', badge: '#1 Pick', desc: 'Medium-feel foam with a 10/10 overall score.' },
  { id: 'plushbeds-signature-bliss', label: 'Best Organic', badge: '10/10 Overall', desc: 'Latex hybrid with a broad certification profile; verify current scope.' },
  { id: 'vaya-hybrid', label: 'Best Value', badge: '10/10 Value', desc: 'Budget hybrid with 10/10 Value and Response Time scores.' },
  { id: 'nest-bedding-sparrow', label: 'Trial Flexibility', badge: '10/10 Trial', desc: 'Hybrid with a top recorded Trial Period score.' },
  { id: 'ghostbed-luxe', label: 'Cooling Foam', badge: '10/10 Cooling', desc: 'All-foam model with top Cooling and Motion Transfer scores.' },
  { id: 'westin-heavenly-bed', label: 'Hotel-Style Feel', badge: '10/10 Overall', desc: 'Pillow-top innerspring with strong edge and response scores.' },
].map(config => {
  const mattress = allMattresses.find(item => item.id === config.id);
  if (!mattress) throw new Error(`Missing homepage pick: ${config.id}`);
  return { ...config, name: mattress.name, score: mattress.scores.overall, href: `/reviews/${mattress.id}` };
});
const featuredComparisons = [
  'amerisleep-organica-vs-avocado-green',
  'amerisleep-as5-hybrid-vs-leesa-sapira-chill-hybrid',
  'amerisleep-as6-black-series-vs-saatva-rx',
].map(slug => {
  const comparison = comparisons.find(item => item.slug === slug);
  if (!comparison) throw new Error(`Missing homepage comparison: ${slug}`);
  const mattressA = allMattresses.find(item => item.id === comparison.mattressAId);
  const mattressB = allMattresses.find(item => item.id === comparison.mattressBId);
  if (!mattressA || !mattressB) throw new Error(`Missing homepage comparison models: ${slug}`);
  return { comparison, mattressA, mattressB };
});

const homepageFaqs = [
  {
    q: 'How does PureSleep score mattresses?',
    a: 'PureSleep uses one seven-metric editorial scorecard: Overall, Value, Edge Support, Trial Period, Response Time, Motion Transfer, and Cooling & Breathability. Every field uses a 0-10 scale, and the same definitions apply to all covered brands.',
  },
  {
    q: 'How many brands and mattress models does PureSleep cover?',
    a: 'The current review library covers 59 mattress models across 24 brands, plus 30 head-to-head comparisons and 18 ranked buying categories.',
  },
  {
    q: 'Are PureSleep scores customer ratings or laboratory results?',
    a: 'No. The scores are editorial comparisons from the published PureSleep score dataset. They are not clinical findings, laboratory measurements, manufacturer ratings, or collected customer ratings.',
  },
  {
    q: 'How should I use a mattress ranking?',
    a: 'Start with the category that matches your sleep position, comfort preference, budget, or shared-bed needs. Then compare the full seven-metric scorecard, firmness, construction, trial policy, warranty, and model availability before purchasing.',
  },
  {
    q: 'Which mattress details should I verify before buying?',
    a: 'Verify current price, stock, specifications, certification scope, shipping, trial, return, and warranty terms on the brand\'s official site. PureSleep labels recorded prices and policy fields as reference data because those details can change.',
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    "name": "PureSleep",
    "url": SITE_URL,
    "description": "Multi-brand mattress reviews, rankings, and buying guides covering 59 models across 24 brands. Updated July 2026.",
    "publisher": { "@id": `${SITE_URL}/#organization` }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${SITE_URL}/#organization`,
    "name": "PureSleep",
    "url": SITE_URL,
    "logo": SITE_URL + "/logo.svg"
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${SITE_URL}/about/#editorial-team`,
    "name": "PureSleep Editorial Team",
    "url": `${SITE_URL}/about/#editorial-team`,
    "parentOrganization": { "@id": `${SITE_URL}/#organization` }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": homepageFaqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": { "@type": "Answer", "text": faq.a }
    }))
  }
];
---

<BaseLayout 
  title="Best Mattress of 2026 | 59 Models Scored | PureSleep"
  description="Compare 59 mattresses across 24 brands with PureSleep's seven-metric editorial scorecards, ranked categories, and head-to-head charts."
  ogTitle="Best Mattress of 2026 — PureSleep"
  ogImage="/images/mattresses/amerisleep-as3.webp"
  ogType="website"
  canonicalUrl={`${SITE_URL}/`}
  lastUpdated="2026-07-14"
  jsonLd={jsonLd}
>
  <div>
    <Hero client:load />
    
    <!-- Coverage Banner -->
    <div class="w-full bg-secondary-container py-4 flex flex-col justify-center items-center px-margin-mobile relative z-10 border-y border-secondary/20">
      <span class="text-on-secondary-container font-headline-md text-headline-md text-center tracking-normal font-bold">
        59 SCORED MODELS ACROSS 24 MATTRESS BRANDS
      </span>
      <span class="text-on-secondary-container/80 text-label-sm font-label-sm uppercase tracking-normal mt-2 bg-white/40 px-3 py-1 rounded-full border border-white/50 shadow-sm font-bold">
        30 comparison charts · 18 ranked categories · updated {formatDateOnly("2026-07-14")}
      </span>
    </div>
    
    <!-- Main Content -->
    <main class="flex-1 w-full flex flex-col relative z-10 bg-background/50">
      <StatsRow client:visible />
      <FindYourMatch client:visible />
      <ScoreSheet client:visible />
      
<!-- Top Picks By Category -->
<section class="py-16 max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
  <h2 class="text-display-lg font-display-lg text-primary mb-3">Top picks by category</h2>
  <p class="text-body-lg text-on-surface-variant mb-10 max-w-2xl">Cross-brand leaders from the same published scorecard, with full reviews behind every pick.</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {featuredPicks.map(pick => (
      <a href={pick.href} class="glass-panel p-6 rounded-lg border border-outline-variant/30 hover:border-secondary/40 transition-all group flex flex-col gap-3">
        <div class="flex items-center justify-between">
          <span class="text-label-sm font-label-sm uppercase tracking-normal text-secondary font-bold">{pick.label}</span>
          <span class="bg-primary/10 text-primary text-xs font-bold px-2 py-1 rounded-full">{pick.badge}</span>
        </div>
        <h3 class="text-headline-md font-headline-md text-primary group-hover:text-secondary transition-colors">{pick.name}</h3>
        <p class="text-body-md text-on-surface-variant">{pick.desc}</p>
        <div class="flex items-center justify-between mt-auto pt-3 border-t border-outline-variant/20">
          <span class="text-label-sm text-on-surface-variant">PureSleep Score</span>
          <span class="text-secondary font-bold text-title-md">{pick.score}/10</span>
        </div>
      </a>
    ))}
  </div>
</section>

      <UseCases client:visible />
      <LatestGuides />

<!-- Head-to-Head Comparisons -->
<section class="py-16 max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
  <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-10">
    <div>
      <h2 class="text-display-lg font-display-lg text-primary mb-3">Head-to-head comparisons</h2>
      <p class="text-body-lg text-on-surface-variant max-w-2xl">Explore 30 matchups with a crawlable chart for all seven score fields on every comparison page.</p>
    </div>
    <a href="/comparison" class="shrink-0 text-secondary font-label-sm font-bold uppercase tracking-normal hover:text-primary transition-colors">
      All 30 comparisons →
    </a>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    {featuredComparisons.map(({ comparison, mattressA, mattressB }) => (
      <a href={`/comparison/${comparison.slug}/`} class="glass-panel rounded-lg p-5 border border-outline-variant hover:border-secondary transition-colors group flex flex-col gap-3">
        <div class="flex items-center gap-2 font-bold text-primary">
          <span class="text-title-md">{mattressA.name}</span>
          <span class="text-on-surface-variant font-normal text-body-md">vs</span>
          <span class="text-title-md">{mattressB.name}</span>
        </div>
        <p class="text-body-md text-on-surface-variant flex-1">{comparison.verdict}</p>
        <span class="text-secondary text-label-sm font-bold uppercase tracking-normal group-hover:text-primary transition-colors">Compare →</span>
      </a>
    ))}
  </div>
</section>

      <Methodology client:visible />
      
<!-- Homepage FAQ -->
<section class="py-16 max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
  <h2 class="text-display-lg font-display-lg text-primary mb-3">Frequently asked questions</h2>
  <p class="text-body-lg text-on-surface-variant mb-10 max-w-2xl">Direct answers about the scorecard, coverage, evidence limits, and how to use the rankings.</p>
  <div class="flex flex-col gap-3 max-w-3xl">
    {homepageFaqs.map(faq => (
      <details class="group glass-panel rounded-lg border border-outline-variant/30 overflow-hidden">
        <summary class="flex justify-between items-center cursor-pointer p-6 font-bold text-on-surface list-none text-body-lg">
          {faq.q}
          <span class="transition-transform group-open:rotate-180 shrink-0 ml-4">
            <svg fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <div class="px-6 pb-6 text-body-md text-on-surface-variant leading-relaxed border-t border-outline-variant/10 pt-4">
          {faq.a}
        </div>
      </details>
    ))}
  </div>
</section>

      <FinalPick client:visible />
    </main>
  </div>
</BaseLayout>
